# =============================================================================
# NextGen Move — environment variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local (it is gitignored).
# =============================================================================

# -----------------------------------------------------------------------------
# Firebase Client SDK (public — safe to expose in the browser)
# From Firebase Console → Project settings → Your apps → Web app config
# -----------------------------------------------------------------------------

# Web API key
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key

# Auth domain, e.g. your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com

# Firebase project ID
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id

# Storage bucket, e.g. your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# Cloud Messaging sender ID
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012

# Web app ID
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456

# -----------------------------------------------------------------------------
# Firebase Admin SDK (server only — never expose to the client)
# From Firebase Console → Project settings → Service accounts → Generate new key
# -----------------------------------------------------------------------------

# Service account project ID (usually same as NEXT_PUBLIC_FIREBASE_PROJECT_ID)
FIREBASE_ADMIN_PROJECT_ID=your-project-id

# Service account client email, e.g. firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Service account private key — paste the full key; use \n for line breaks in .env.local
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# -----------------------------------------------------------------------------
# Session signing (server only — used by middleware role checks)
# Generate with: openssl rand -base64 32
# -----------------------------------------------------------------------------

SESSION_SECRET=replace-with-a-long-random-string

# -----------------------------------------------------------------------------
# Seed script (scripts/seed.ts — run with: npm run seed)
# Creates super-admin + operational config only (never demo entities)
# -----------------------------------------------------------------------------

SEED_ADMIN_EMAIL=admin@nextgenmove.agency
SEED_ADMIN_PASSWORD=replace-with-a-strong-password
# Optional comma-separated aliases that also resolve as admin during session
# SEED_ADMIN_EMAILS=admin@venturo.ae

# -----------------------------------------------------------------------------
# Observability (optional — production should set via secrets manager)
# -----------------------------------------------------------------------------

# SENTRY_DSN=https://...@sentry.io/...
# APP_ENV=production

# -----------------------------------------------------------------------------
# App URL + integration secret encryption (server)
# -----------------------------------------------------------------------------

# Public site origin used for Stripe success/cancel + webhook docs
# Production: https://www.nextgenmove.agency
NEXT_PUBLIC_APP_URL=http://localhost:3002

# Encrypts integration_secrets at rest (openssl rand -base64 32)
# INTEGRATION_ENCRYPTION_KEY=replace-with-a-long-random-string

# Resend — fallback when Gmail SMTP is unavailable
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=noreply@your-domain.com
# RESEND_FROM_NAME=Nextgenmove

# Gmail SMTP — primary transactional email (Google App Password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-16-char-app-password
# SMTP_FROM_EMAIL=you@gmail.com
# SMTP_FROM_NAME=Nextgenmove

# -----------------------------------------------------------------------------
# Cron (server only)
# -----------------------------------------------------------------------------

# Protects /api/cron/* routes — Authorization: Bearer <CRON_SECRET>
# CRON_SECRET=replace-with-a-long-random-string

# YouTube Data API key: prefer Admin → Integrations → YouTube (encrypted in
# integration_secrets). Optional env fallback if Integrations is not connected:
# YOUTUBE_API_KEY=your-youtube-data-api-key

